<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Expense: List View
    =================================================================== -->
    <record id="view_construction_expense_list" model="ir.ui.view">
        <field name="name">construction.expense.list</field>
        <field name="model">construction.expense</field>
        <field name="arch" type="xml">
            <list string="Expenses" editable="bottom"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'confirmed'">
                <field name="name" readonly="1"/>
                <field name="project_id"/>
                <field name="date" widget="jalali_date"/>
                <field name="project_phase_id" optional="show"/>
                <field name="expense_type_id"/>
                <field name="description"/>
                <field name="partner_id" optional="hide"/>
                <field name="payment_source"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="amount" sum="Total"/>
                <field name="receipt_ref" optional="hide"/>
                <field name="state" widget="badge" readonly="1"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
                <button name="action_open_form" type="object"
                        icon="fa-external-link" title="Open Full Form"
                        string="" class="btn-sm btn-secondary"/>
            </list>
        </field>
    </record>

    <!-- ===================================================================
         Expense: Kanban View
    =================================================================== -->
    <record id="view_construction_expense_kanban" model="ir.ui.view">
        <field name="name">construction.expense.kanban</field>
        <field name="model">construction.expense</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">

                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="expense_type_id"/>
                <field name="description"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="payment_source"/>
                <field name="partner_id"/>
                <field name="project_phase_id"/>
                <field name="receipt_file"/>
                <field name="receipt_ref"/>
                <field name="recorded_by"/>
                <field name="state"/>

                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card">

                            <!-- Colored accent bar by payment source -->
                            <div t-att-class="'p-1 ' + (record.payment_source.raw_value === 'payroll_card' ? 'bg-info' : record.payment_source.raw_value === 'employer_cash' ? 'bg-success' : 'bg-warning')"
                                 style="border-radius:4px 4px 0 0; height:6px;"/>

                            <div class="p-2">

                                <!-- Header: icon + name + state badge -->
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <i t-att-class="'fa fa-fw ' + (record.payment_source.raw_value === 'payroll_card' ? 'fa-credit-card text-info' : record.payment_source.raw_value === 'employer_cash' ? 'fa-money text-success' : 'fa-bank text-warning')" title="Payment Source"/>
                                        <strong class="text-truncate" style="max-width:140px;">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-success="state == 'confirmed'"
                                           decoration-danger="state == 'cancelled'"/>
                                </div>

                                <!-- Payment source badge -->
                                <div class="mb-2">
                                    <span t-att-class="'badge rounded-pill ' + (record.payment_source.raw_value === 'payroll_card' ? 'text-bg-info' : record.payment_source.raw_value === 'employer_cash' ? 'text-bg-success' : 'text-bg-warning')">
                                        <t t-esc="record.payment_source.value"/>
                                    </span>
                                </div>

                                <!-- Date -->
                                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                                    <i class="fa fa-calendar fa-fw" title="Date"/>
                                    <field name="date" widget="jalali_date"/>
                                </div>

                                <!-- Project -->
                                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                                    <i class="fa fa-building fa-fw" title="Project"/>
                                    <field name="project_id"/>
                                </div>

                                <!-- Phase (if set) -->
                                <div t-if="record.project_phase_id.raw_value"
                                     class="d-flex align-items-center gap-2 text-muted small mb-1">
                                    <i class="fa fa-sitemap fa-fw" title="Phase"/>
                                    <field name="project_phase_id"/>
                                </div>

                                <!-- Expense type -->
                                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                                    <i class="fa fa-tag fa-fw" title="Expense Type"/>
                                    <field name="expense_type_id"/>
                                </div>

                                <!-- Description -->
                                <div class="d-flex align-items-center gap-2 small mb-2">
                                    <i class="fa fa-align-left fa-fw text-muted" title="Description"/>
                                    <span class="fst-italic text-muted">
                                        <field name="description"/>
                                    </span>
                                </div>

                                <!-- Amount — prominent -->
                                <div class="d-flex align-items-center gap-2 my-2 py-2"
                                     style="border-top:1px solid #e9ecef; border-bottom:1px solid #e9ecef;">
                                    <i class="fa fa-minus-circle fa-fw text-danger" title="Amount"/>
                                    <span class="fw-bold fs-5 text-danger">
                                        <field name="amount"/>
                                    </span>
                                </div>

                                <!-- Footer: recorded_by + receipt ref -->
                                <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">
                                    <div class="d-flex align-items-center gap-1">
                                        <i class="fa fa-user fa-fw" title="Recorded By"/>
                                        <field name="recorded_by"/>
                                    </div>
                                    <div t-if="record.receipt_ref.raw_value" class="d-flex align-items-center gap-1">
                                        <i class="fa fa-hashtag fa-fw" title="Receipt Reference"/>
                                        <field name="receipt_ref"/>
                                    </div>
                                </div>

                                <!-- Receipt image (if present) — click opens modal -->
                                <t t-if="record.receipt_file.raw_value">
                                    <div class="mt-2 position-relative rounded overflow-hidden"
                                         style="cursor:pointer;"
                                         t-att-data-bs-target="'#expenseReceiptModal_' + record.id.raw_value"
                                         data-bs-toggle="modal">
                                        <img t-att-src="'/web/image/construction.expense/' + record.id.raw_value + '/receipt_file'"
                                             style="width:100%; height:140px; object-fit:cover; display:block;"
                                             alt="Receipt"/>
                                        <div style="position:absolute; inset:0;
                                                    background:linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%);"/>
                                        <span class="fa fa-search-plus position-absolute"
                                              title="View Receipt"
                                              style="bottom:8px; right:8px;
                                                     background:rgba(0,0,0,0.6);
                                                     color:white; padding:6px;
                                                     border-radius:50%; font-size:14px;"/>
                                    </div>

                                    <!-- Bootstrap 5 modal for full-size preview -->
                                    <div t-att-id="'expenseReceiptModal_' + record.id.raw_value"
                                         class="modal fade" role="dialog" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered modal-lg">
                                            <div class="modal-content">
                                                <div class="modal-header py-2">
                                                    <h5 class="modal-title">
                                                        <i class="fa fa-file-image-o me-2" title="Receipt Image"/>
                                                        <field name="name"/> — Receipt
                                                    </h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"/>
                                                </div>
                                                <div class="modal-body p-1 text-center">
                                                    <img t-att-src="'/web/image/construction.expense/' + record.id.raw_value + '/receipt_file'"
                                                         class="img-fluid rounded" alt="Receipt"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ===================================================================
         Expense: Form View
    =================================================================== -->
    <record id="view_construction_expense_form" model="ir.ui.view">
        <field name="name">construction.expense.form</field>
        <field name="model">construction.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('confirmed', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <!-- Title -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Draft receipt hint -->
                    <div class="alert alert-info d-flex align-items-center gap-2 mb-3"
                         role="alert"
                         invisible="state != 'draft'">
                        <i class="fa fa-info-circle fa-lg" title="Info"/>
                        <span>A receipt reference number or file attachment is required before confirming this expense.</span>
                    </div>

                    <!-- Confirmed banner -->
                    <div class="alert alert-success d-flex align-items-center gap-2 mb-3"
                         role="alert"
                         invisible="state != 'confirmed'">
                        <i class="fa fa-check-circle fa-lg" title="Confirmed"/>
                        <span><strong>Expense Confirmed.</strong> This expense has been recorded and approved.</span>
                    </div>

                    <!-- Cancelled banner -->
                    <div class="alert alert-danger d-flex align-items-center gap-2 mb-3"
                         role="alert"
                         invisible="state != 'cancelled'">
                        <i class="fa fa-ban fa-lg" title="Cancelled"/>
                        <span><strong>Cancelled.</strong> This expense has been cancelled.</span>
                    </div>

                    <group>
                        <group string="Expense Details">
                            <field name="project_id"/>
                            <field name="date" widget="jalali_date"/>
                            <field name="project_phase_id"/>
                            <field name="expense_type_id"/>
                            <field name="description"/>
                            <field name="partner_id"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Payment">
                            <field name="payment_source"/>
                            <field name="recorded_by"/>
                            <field name="include_in_contractor_fee"/>
                        </group>
                    </group>

                    <group string="Receipt">
                        <field name="receipt_ref" placeholder="e.g. REC-2024-001"/>
                        <field name="receipt_file" filename="receipt_filename"
                               widget="binary"/>
                        <field name="receipt_filename" invisible="1"/>
                        <div class="mt-2" invisible="not receipt_file" colspan="2">
                            <field name="receipt_file"
                                   widget="image"
                                   readonly="1"
                                   class="img img-fluid rounded"
                                   style="max-height:400px;"/>
                        </div>
                    </group>

                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ===================================================================
         Expense: Search + Filters
    =================================================================== -->
    <record id="view_construction_expense_search" model="ir.ui.view">
        <field name="name">construction.expense.search</field>
        <field name="model">construction.expense</field>
        <field name="arch" type="xml">
            <search string="Search Expenses">
                <field name="name"/>
                <field name="project_id"/>
                <field name="project_phase_id"/>
                <field name="partner_id"/>
                <field name="receipt_ref"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <separator/>
                <filter string="Payroll Card" name="payroll_card"
                        domain="[('payment_source','=','payroll_card')]"/>
                <filter string="Employer Cash" name="employer_cash"
                        domain="[('payment_source','=','employer_cash')]"/>
                <filter string="Employer Check" name="employer_check"
                        domain="[('payment_source','=','employer_check')]"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        domain="[('date','&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <group>
                    <filter string="Project" name="group_project"
                            context="{'group_by': 'project_id'}"/>
                    <filter string="Project Phase" name="group_phase"
                            context="{'group_by': 'project_phase_id'}"/>
                    <filter string="Expense Type" name="group_type"
                            context="{'group_by': 'expense_type_id'}"/>
                    <filter string="Payment Source" name="group_payment"
                            context="{'group_by': 'payment_source'}"/>
                    <filter string="Month" name="group_month"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot view for expense reporting -->
    <record id="view_construction_expense_pivot" model="ir.ui.view">
        <field name="name">construction.expense.pivot</field>
        <field name="model">construction.expense</field>
        <field name="arch" type="xml">
            <pivot string="Expense Analysis">
                <field name="project_id" type="row"/>
                <field name="expense_type_id" type="row"/>
                <field name="date" interval="month" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Action -->
    <record id="action_construction_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">construction.expense</field>
        <field name="view_mode">kanban,list,form,pivot</field>
        <field name="search_view_id" ref="view_construction_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record your first expense</p>
        </field>
    </record>
</odoo>
