<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Invoice: List View
    =================================================================== -->
    <record id="view_construction_invoice_list" model="ir.ui.view">
        <field name="name">construction.invoice.list</field>
        <field name="model">construction.invoice</field>
        <field name="arch" type="xml">
            <list string="Invoices"
                  decoration-success="payment_state == 'paid'"
                  decoration-warning="payment_state == 'partial'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="project_phase_id" optional="show"/>
                <field name="invoice_date" widget="jalali_date"/>
                <field name="partner_id"/>
                <field name="invoice_number"/>
                <field name="amount_total" sum="Total Invoiced"/>
                <field name="amount_paid" sum="Total Paid"/>
                <field name="amount_residual" sum="Total Outstanding"/>
                <field name="payment_state" widget="badge"
                       decoration-success="payment_state == 'paid'"
                       decoration-warning="payment_state == 'partial'"
                       decoration-info="payment_state == 'not_paid'"/>
                <field name="amount_prepaid" sum="Total Prepaid" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'posted'"
                       decoration-danger="state == 'cancelled'"/>
                <button name="action_pay_on_account" string="Pay on Account"
                        type="object" class="btn-secondary"
                        invisible="state != 'draft'"/>
                <button name="action_register_payment" string="Pay"
                        type="object" class="btn-secondary"
                        invisible="state != 'posted' or payment_state == 'paid'"/>
            </list>
        </field>
    </record>

    <!-- ===================================================================
         Invoice: Form View
    =================================================================== -->
    <record id="view_construction_invoice_form" model="ir.ui.view">
        <field name="name">construction.invoice.form</field>
        <field name="model">construction.invoice</field>
        <field name="arch" type="xml">
            <form string="Invoice">
                <header>
                    <button name="action_create_vendor_bill" string="Create Vendor Bill"
                            type="object" class="btn-primary"
                            invisible="state != 'draft' or account_move_id != False"/>
                    <button name="action_pay_on_account" string="Pay on Account"
                            type="object" class="btn-secondary"
                            invisible="state != 'draft'"/>
                    <button name="action_register_payment" string="Register Payment"
                            type="object" class="btn-primary"
                            invisible="state != 'posted' or payment_state == 'paid'"/>
                    <button name="action_open_vendor_bill" string="Open Vendor Bill"
                            type="object"
                            invisible="account_move_id == False"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state == 'cancelled'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <!-- Payment status banner -->
                    <div class="alert alert-success" role="alert"
                         invisible="payment_state != 'paid'">
                        This invoice is fully paid.
                    </div>
                    <div class="alert alert-warning" role="alert"
                         invisible="payment_state != 'partial'">
                        This invoice is partially paid. Outstanding balance:
                        <field name="amount_residual" readonly="1" nolabel="1"/>
                    </div>

                    <!-- Payments on account banner (draft only) -->
                    <div class="alert alert-info" role="alert"
                         invisible="state != 'draft' or amount_prepaid == 0">
                        Pay-on-account payments recorded:
                        <field name="amount_prepaid" readonly="1" nolabel="1"/>
                        — these will be automatically reconciled when the vendor bill is created.
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Invoice Details">
                            <field name="project_id"/>
                            <field name="project_phase_id"/>
                            <field name="partner_id"/>
<!--                            <field name="invoice_date"/>-->
                            <field
                    name="invoice_date"
                    widget="jalali_date"

                    options="{'highlight_holidays': false}"
                />
                            <field name="invoice_number" placeholder="Vendor invoice ref"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Amounts">
                            <field name="amount_total"/>
                            <field name="amount_prepaid" readonly="1"
                                   invisible="amount_prepaid == 0"/>
                            <field name="amount_paid" readonly="1"/>
                            <field name="amount_residual" readonly="1"/>
                            <field name="payment_state" readonly="1"/>
                            <field name="include_in_contractor_fee"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"
                               placeholder="Scope of work or services covered..."/>
                    </group>
                    <group string="Invoice Document">
                        <field name="receipt_ref" placeholder="e.g. INV-VND-0042"/>
                        <field name="receipt_file" filename="receipt_filename"
                               widget="binary"/>
                        <field name="receipt_filename" invisible="1"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Additional remarks..."/>
                    </group>

                    <!-- Unified payments list (on-account + final) -->
                    <field name="prepayment_ids" string="Payments"
                           invisible="not prepayment_ids">
                        <list string="Payments" create="0" delete="0">
                            <field name="name" readonly="1"/>
                            <field name="payment_date" readonly="1"/>
                            <field name="amount" sum="Total" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="payment_source" widget="badge" readonly="1"
                                   decoration-info="payment_source == 'payroll_card'"
                                   decoration-success="payment_source in ('employer_cash', 'employer_check')"/>
                            <field name="state" widget="badge" readonly="1"
                                   decoration-success="state == 'posted'"
                                   decoration-info="state == 'in_process'"
                                   decoration-warning="state == 'draft'"
                                   decoration-danger="state == 'cancel'"/>
                            <field name="receipt_file" widget="image" readonly="1"
                                   options="{'size': [38, 38]}"
                                   string="Receipt"/>
                            <button name="action_view_receipt" type="object"
                                    icon="fa-search-plus" title="View Full Receipt"
                                    invisible="not receipt_file"/>
                            <button name="action_cancel" type="object"
                                    icon="fa-times" title="Cancel this payment"
                                    invisible="state not in ('draft', 'posted', 'in_process')"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ===================================================================
         Invoice: Search
    =================================================================== -->
    <record id="view_construction_invoice_search" model="ir.ui.view">
        <field name="name">construction.invoice.search</field>
        <field name="model">construction.invoice</field>
        <field name="arch" type="xml">
            <search string="Search Invoices">
                <field name="name"/>
                <field name="project_id"/>
                <field name="project_phase_id"/>
                <field name="partner_id"/>
                <field name="invoice_number"/>
                <separator/>
                <filter string="Not Paid" name="not_paid"
                        domain="[('payment_state','=','not_paid')]"/>
                <filter string="Partially Paid" name="partial"
                        domain="[('payment_state','=','partial')]"/>
                <filter string="Paid" name="paid"
                        domain="[('payment_state','=','paid')]"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        domain="[('invoice_date','&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <group>
                    <filter string="Project" name="group_project"
                            context="{'group_by': 'project_id'}"/>
                    <filter string="Project Phase" name="group_phase"
                            context="{'group_by': 'project_phase_id'}"/>
                    <filter string="Vendor" name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Payment Status" name="group_payment"
                            context="{'group_by': 'payment_state'}"/>
                    <filter string="Month" name="group_month"
                            context="{'group_by': 'invoice_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_construction_invoice" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">construction.invoice</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_construction_invoice_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record your first invoice</p>
        </field>
    </record>
</odoo>
