<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Card Transaction: List View
    =================================================================== -->
    <record id="view_construction_card_transaction_list" model="ir.ui.view">
        <field name="name">construction.card.transaction.list</field>
        <field name="model">construction.card.transaction</field>
        <field name="arch" type="xml">
            <list string="Payroll Card Transactions"
                  decoration-success="transaction_type == 'deposit' and state == 'confirmed'"
                  decoration-warning="transaction_type == 'withdrawal' and state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date" widget="jalali_date"/>
                <field name="transaction_type"/>
                <field name="description"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="amount" sum="Total"/>
                <field name="receipt_ref"/>
                <field name="performed_by"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>


    <!-- ===================================================================
         Card Transaction: Kanban View
    =================================================================== -->
    <record id="view_construction_card_transaction_kanban" model="ir.ui.view">
        <field name="name">construction.card.transaction.kanban</field>
        <field name="model">construction.card.transaction</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">

                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="transaction_type"/>
                <field name="description"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="receipt_file"/>
                <field name="receipt_ref"/>
                <field name="performed_by"/>
                <field name="state"/>

                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card">

                            <!-- Colored accent bar by transaction type -->
                            <div t-att-class="'p-1 ' + (record.transaction_type.raw_value === 'deposit' ? 'bg-success' : 'bg-danger')"
                                 style="border-radius:4px 4px 0 0; height:6px;"/>

                            <div class="p-2">

                                <!-- Header: icon + name + state badge -->
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <i t-att-class="'fa fa-fw ' + (record.transaction_type.raw_value === 'deposit' ? 'fa-arrow-down text-success' : 'fa-arrow-up text-danger')" title="Transaction Type"/>
                                        <strong class="text-truncate" style="max-width:140px;">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-success="state == 'confirmed'"
                                           decoration-danger="state == 'cancelled'"/>
                                </div>

                                <!-- Transaction type badge -->
                                <div class="mb-2">
                                    <span t-att-class="'badge rounded-pill ' + (record.transaction_type.raw_value === 'deposit' ? 'text-bg-success' : 'text-bg-danger')">
                                        <t t-esc="record.transaction_type.value"/>
                                    </span>
                                </div>

                                <!-- Date -->
                                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                                    <i class="fa fa-calendar fa-fw" title="Date"/>
                                    <field name="date" widget="jalali_date"/>
                                </div>

                                <!-- Project -->
                                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                                    <i class="fa fa-building fa-fw" title="Project"/>
                                    <field name="project_id"/>
                                </div>

                                <!-- Description -->
                                <div class="d-flex align-items-center gap-2 small mb-2">
                                    <i class="fa fa-align-left fa-fw text-muted" title="Description"/>
                                    <span class="fst-italic text-muted">
                                        <field name="description"/>
                                    </span>
                                </div>

                                <!-- Amount — prominent + color-coded -->
                                <div class="d-flex align-items-center gap-2 my-2 py-2"
                                     style="border-top:1px solid #e9ecef; border-bottom:1px solid #e9ecef;">
                                    <i t-att-class="'fa fa-fw ' + (record.transaction_type.raw_value === 'deposit' ? 'fa-plus-circle text-success' : 'fa-minus-circle text-danger')" title="Amount"/>
                                    <span t-att-class="'fw-bold fs-5 ' + (record.transaction_type.raw_value === 'deposit' ? 'text-success' : 'text-danger')">
                                        <field name="amount"/>
                                    </span>
                                </div>

                                <!-- Footer: performed_by + receipt ref -->
                                <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">
                                    <div class="d-flex align-items-center gap-1">
                                        <i class="fa fa-user fa-fw" title="Performed By"/>
                                        <field name="performed_by"/>
                                    </div>
                                    <div t-if="record.receipt_ref.raw_value" class="d-flex align-items-center gap-1">
                                        <i class="fa fa-hashtag fa-fw" title="Receipt Reference"/>
                                        <field name="receipt_ref"/>
                                    </div>
                                </div>

                                <!-- Receipt image (if present) — click opens modal -->
                                <t t-if="record.receipt_file.raw_value">
                                    <div class="mt-2 position-relative rounded overflow-hidden"
                                         style="cursor:pointer;"
                                         t-att-data-bs-target="'#receiptModal_' + record.id.raw_value"
                                         data-bs-toggle="modal">
                                        <img t-att-src="'/web/image/construction.card.transaction/' + record.id.raw_value + '/receipt_file'"
                                             style="width:100%; height:140px; object-fit:cover; display:block;"
                                             alt="Receipt"/>
                                        <div style="position:absolute; inset:0;
                                                    background:linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%);"/>
                                        <span class="fa fa-search-plus position-absolute"
                                              title="View Receipt"
                                              style="bottom:8px; right:8px;
                                                     background:rgba(0,0,0,0.6);
                                                     color:white; padding:6px;
                                                     border-radius:50%; font-size:14px;"/>
                                    </div>

                                    <!-- Bootstrap 5 modal for full-size preview -->
                                    <div t-att-id="'receiptModal_' + record.id.raw_value"
                                         class="modal fade" role="dialog" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered modal-lg">
                                            <div class="modal-content">
                                                <div class="modal-header py-2">
                                                    <h5 class="modal-title">
                                                        <i class="fa fa-file-image-o me-2" title="Receipt Image"/>
                                                        <field name="name"/> — Receipt
                                                    </h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"/>
                                                </div>
                                                <div class="modal-body p-1 text-center">
                                                    <img t-att-src="'/web/image/construction.card.transaction/' + record.id.raw_value + '/receipt_file'"
                                                         class="img-fluid rounded" alt="Receipt"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ===================================================================
         Card Transaction: Form View
    =================================================================== -->
    <record id="view_construction_card_transaction_form" model="ir.ui.view">
        <field name="name">construction.card.transaction.form</field>
        <field name="model">construction.card.transaction</field>
        <field name="arch" type="xml">
            <form string="Payroll Card Transaction">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('confirmed', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <!-- Title -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Confirmed deposit banner -->
                    <div class="alert alert-success d-flex align-items-center gap-2 mb-3"
                         role="alert"
                         invisible="not (state == 'confirmed' and transaction_type == 'deposit')">
                        <i class="fa fa-check-circle fa-lg" title="Confirmed"/>
                        <span><strong>Deposit Confirmed.</strong> Funds have been deposited to the payroll card.</span>
                    </div>

                    <!-- Confirmed withdrawal banner -->
                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3"
                         role="alert"
                         invisible="not (state == 'confirmed' and transaction_type == 'withdrawal')">
                        <i class="fa fa-exclamation-triangle fa-lg" title="Warning"/>
                        <span><strong>Withdrawal Confirmed.</strong> Cash has been withdrawn from the payroll card.</span>
                    </div>

                    <!-- Draft receipt hint -->
                    <div class="alert alert-info d-flex align-items-center gap-2 mb-3"
                         role="alert"
                         invisible="state != 'draft'">
                        <i class="fa fa-info-circle fa-lg" title="Info"/>
                        <span>A receipt reference number or file attachment is required before confirming this transaction.</span>
                    </div>

                    <group>
                        <group string="Transaction Details">
                            <field name="project_id"/>
                            <field name="transaction_type"/>
                            <field name="date" widget="jalali_date"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="description"/>
                        </group>
                        <group string="Tracking">
                            <field name="performed_by"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Receipt">
                        <field name="receipt_ref"
                               placeholder="e.g. DEP-2024-001"/>
                        <field name="receipt_file"
                               filename="receipt_filename"
                               widget="binary"/>
                        <field name="receipt_filename" invisible="1"/>
                        <div class="mt-2" invisible="not receipt_file" colspan="2">
                            <field name="receipt_file"
                                   widget="image"
                                   readonly="1"
                                   class="img img-fluid rounded"
                                   style="max-height:400px;"/>
                        </div>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ===================================================================
         Card Transaction: Search
    =================================================================== -->
    <record id="view_construction_card_transaction_search" model="ir.ui.view">
        <field name="name">construction.card.transaction.search</field>
        <field name="model">construction.card.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Card Transactions">
                <field name="name"/>
                <field name="project_id"/>
                <field name="receipt_ref"/>
                <separator/>
                <filter string="Deposits" name="deposits"
                        domain="[('transaction_type','=','deposit')]"/>
                <filter string="Withdrawals" name="withdrawals"
                        domain="[('transaction_type','=','withdrawal')]"/>
                <separator/>
                <filter string="Confirmed" name="confirmed"
                        domain="[('state','=','confirmed')]"/>
                <filter string="Draft" name="draft"
                        domain="[('state','=','draft')]"/>
                <group>
                    <filter string="Project" name="group_project"
                            context="{'group_by': 'project_id'}"/>
                    <filter string="Type" name="group_type"
                            context="{'group_by': 'transaction_type'}"/>
                    <filter string="Month" name="group_month"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_construction_card_transaction" model="ir.actions.act_window">
        <field name="name">Payroll Card Transactions</field>
        <field name="res_model">construction.card.transaction</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_construction_card_transaction_search"/>
    </record>
</odoo>
