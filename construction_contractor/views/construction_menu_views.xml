<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Top-level menu -->
    <menuitem id="menu_construction_root"
              name="Construction"
              web_icon="construction_contractor,static/description/icon.png"
              groups="construction_contractor.group_construction_manager,base.group_system"
              sequence="50"/>

    <!-- Projects -->
    <menuitem id="menu_construction_projects"
              name="Projects"
              parent="menu_construction_root"
              groups="construction_contractor.group_construction_manager"
              sequence="10"/>

    <menuitem id="menu_construction_project_list"
              name="All Projects"
              parent="menu_construction_projects"
              action="action_construction_project"
              groups="construction_contractor.group_construction_manager"
              sequence="10"/>

    <!-- Transactions -->
    <menuitem id="menu_construction_transactions"
              name="Transactions"
              parent="menu_construction_root"
              groups="construction_contractor.group_construction_manager"
              sequence="20"/>

    <menuitem id="menu_construction_card_transactions"
              name="Payroll Card"
              parent="menu_construction_transactions"
              action="action_construction_card_transaction"
              groups="construction_contractor.group_construction_manager"
              sequence="10"/>

    <menuitem id="menu_construction_expenses"
              name="Expenses"
              parent="menu_construction_transactions"
              action="action_construction_expense"
              groups="construction_contractor.group_construction_manager"
              sequence="20"/>

    <!-- Contractor Fee -->
    <menuitem id="menu_construction_contractor_fee"
              name="Contractor Fee"
              parent="menu_construction_root"
              groups="construction_contractor.group_construction_manager"
              sequence="35"/>

    <menuitem id="menu_construction_contractor_fee_payments"
              name="Fee Payments"
              parent="menu_construction_contractor_fee"
              action="action_contractor_fee_payment_all"
              groups="construction_contractor.group_construction_manager"
              sequence="10"/>

    <!-- Invoices -->
    <menuitem id="menu_construction_invoices_parent"
              name="Invoices"
              parent="menu_construction_root"
              groups="construction_contractor.group_construction_manager"
              sequence="30"/>

    <menuitem id="menu_construction_invoices"
              name="All Invoices"
              parent="menu_construction_invoices_parent"
              action="action_construction_invoice"
              groups="construction_contractor.group_construction_manager"
              sequence="10"/>

    <!-- Reporting -->
    <menuitem id="menu_construction_reports"
              name="Reports"
              parent="menu_construction_root"
              groups="construction_contractor.group_construction_manager"
              sequence="40"/>

    <menuitem id="menu_construction_financial_balance"
              name="Financial Balance"
              parent="menu_construction_reports"
              action="action_construction_financial_balance"
              groups="construction_contractor.group_construction_manager"
              sequence="5"/>

    <menuitem id="menu_construction_report_project"
              name="Project Financial Summary"
              parent="menu_construction_reports"
              action="action_report_construction_project_summary"
              groups="construction_contractor.group_construction_manager"
              sequence="10"/>

    <menuitem id="menu_construction_report_expense"
              name="Expense Analysis"
              parent="menu_construction_reports"
              action="action_construction_expense"
              groups="construction_contractor.group_construction_manager"
              sequence="20"/>

    <menuitem id="menu_construction_report_invoice"
              name="Invoice Status"
              parent="menu_construction_reports"
              action="action_construction_invoice"
              groups="construction_contractor.group_construction_manager"
              sequence="30"/>

    <!-- Configuration -->
    <menuitem id="menu_construction_configuration"
              name="Configuration"
              parent="menu_construction_root"
              groups="construction_contractor.group_construction_accountant"
              sequence="90"/>

    <menuitem id="menu_construction_project_phases"
              name="Project Phases"
              parent="menu_construction_configuration"
              action="action_construction_project_phase"
              groups="construction_contractor.group_construction_accountant"
              sequence="10"/>

    <menuitem id="menu_construction_expense_types"
              name="Expense Types"
              parent="menu_construction_configuration"
              action="action_construction_expense_type"
              groups="construction_contractor.group_construction_accountant"
              sequence="20"/>
</odoo>
