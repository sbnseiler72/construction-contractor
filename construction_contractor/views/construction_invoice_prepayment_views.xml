<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Receipt Dialog: full-size image preview (opened by action_view_receipt)
    =================================================================== -->
    <record id="view_construction_payment_receipt_wizard_form" model="ir.ui.view">
        <field name="name">construction.payment.receipt.wizard.form</field>
        <field name="model">construction.payment.receipt.wizard</field>
        <field name="arch" type="xml">
            <form string="Receipt">
                <sheet>
                    <div class="oe_title mb-3">
                        <h3>
                            <i class="fa fa-file-image-o me-2 text-muted"/>
                            <field name="payment_name" readonly="1"/>
                        </h3>
                    </div>
                    <field name="receipt_file" widget="image"
                           nolabel="1" readonly="1"
                           options="{'size': [800, 600]}"/>
                </sheet>
                <footer>
                    <button string="Close" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ===================================================================
         Payment: Form View (read-only detail opened from invoice lines)
    =================================================================== -->
    <record id="view_construction_invoice_prepayment_form" model="ir.ui.view">
        <field name="name">construction.invoice.prepayment.form</field>
        <field name="model">construction.invoice.prepayment</field>
        <field name="arch" type="xml">
            <form string="Payment" create="false" edit="false" delete="false">
                <header>
                    <button name="action_cancel" string="Cancel Payment"
                            type="object" class="btn-danger"
                            invisible="state not in ('draft', 'posted', 'in_process')"
                            confirm="Are you sure you want to cancel this payment?"/>
                    <field name="payment_type" widget="badge"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_process,posted,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Invoice">
                            <field name="invoice_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Payment Details">
                            <field name="payment_type" readonly="1"/>
                            <field name="payment_date" readonly="1"
                                   widget="jalali_date"/>
                            <field name="amount" readonly="1"/>
                            <field name="payment_source" readonly="1"/>
                            <field name="memo" readonly="1"/>
                        </group>
                    </group>
                    <group string="Accounting">
                        <field name="account_payment_id" readonly="1"/>
                    </group>
                    <group string="Receipt" invisible="not receipt_file">
                        <field name="receipt_file" widget="image"
                               readonly="1" nolabel="1" colspan="2"
                               options="{'size': [0, 400]}"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ===================================================================
         Pay on Account Wizard: Form View
    =================================================================== -->
    <record id="view_construction_invoice_prepayment_wizard_form" model="ir.ui.view">
        <field name="name">construction.invoice.prepayment.wizard.form</field>
        <field name="model">construction.invoice.prepayment.wizard</field>
        <field name="arch" type="xml">
            <form string="Pay on Account">
                <sheet>
                    <div class="oe_title">
                        <h2>Pay on Account</h2>
                        <p class="text-muted">
                            Record a payment made before the invoice is formalised.
                            An accounting entry will be created immediately and
                            reconciled automatically when the vendor bill is generated.
                        </p>
                    </div>
                    <group>
                        <group string="Invoice">
                            <field name="invoice_id" readonly="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Payment Details">
                            <field name="payment_source"/>
                            <field name="amount"/>
                            <field name="payment_date" widget="jalali_date" options="{'zIndex': '2000'}"/>
                            <field name="memo" placeholder="e.g. Advance payment – INV/2024/00001"/>
                            <field name="post_payment" widget="radio"/>
                        </group>
                    </group>
                    <group string="Journal">
                        <field name="journal_id" readonly="1"
                               help="Auto-selected based on payment source configured on the project"/>
                    </group>
                    <div class="alert alert-warning" role="alert"
                         invisible="journal_id != False">
                        <strong>Warning:</strong> No journal configured for the selected
                        payment source on this project. Please set the Payroll Card Journal
                        or Employer Journal on the project before registering a payment.
                    </div>
                    <group string="Receipt (optional)">
                        <field name="receipt_file" filename="receipt_filename"
                               widget="binary" nolabel="1" colspan="2"/>
                        <field name="receipt_filename" invisible="1"/>
                        <div class="mt-2" invisible="not receipt_file" colspan="2">
                            <field name="receipt_file" widget="image" readonly="1"
                                   class="img img-fluid rounded"
                                   style="max-height:300px;"/>
                        </div>
                    </group>
                </sheet>
                <footer>
                    <button name="action_pay_on_account" string="Pay on Account"
                            type="object" class="btn-primary"
                            invisible="journal_id == False"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
