<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Project: List View
    =================================================================== -->
    <record id="view_construction_project_list" model="ir.ui.view">
        <field name="name">construction.project.list</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <list string="Construction Projects" decoration-info="state == 'draft'"
                  decoration-success="state == 'active'" decoration-muted="state in ('closed', 'cancelled')">
                <field name="code"/>
                <field name="name"/>
                <field name="employer_id"/>
                <field name="manager_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="contracted_amount" sum="Total Contracted"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'closed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ===================================================================
         Project: Form View
    =================================================================== -->
    <record id="view_construction_project_form" model="ir.ui.view">
        <field name="name">construction.project.form</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <form string="Construction Project">
                <header>
                    <button name="action_set_active" string="Activate"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_set_closed" string="Close Project"
                            type="object"
                            invisible="state != 'active'"/>
                    <button name="action_set_cancelled" string="Cancel"
                            type="object"
                            invisible="state not in ('draft', 'active')"/>
                    <button name="action_set_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('closed', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_card_transactions"
                                type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="card_transaction_count" widget="statinfo" string="Card Transactions"/>
                        </button>
                        <button name="action_view_expenses"
                                type="object" class="oe_stat_button" icon="fa-money">
                            <field name="expense_count" widget="statinfo" string="Expenses"/>
                        </button>
                        <button name="action_view_invoices"
                                type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                        <button name="action_view_financial_balance"
                                type="object" class="oe_stat_button" icon="fa-balance-scale">
                            <field name="financial_balance_count" widget="statinfo" string="Balance"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Project Name"/></h1>
                        <div class="o_row">
                            <field name="code" readonly="1"/>
                        </div>
                    </div>

                    <group>
                        <group string="Project Details">
                            <field name="employer_id"/>
                            <field name="manager_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Financial">
                            <field name="contracted_amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="payroll_journal_id"/>
                            <button name="action_create_payroll_journal"
                                    string="Create Payroll Card Journal"
                                    type="object"
                                    class="btn-secondary"
                                    invisible="payroll_journal_id != False"/>
                            <field name="employer_journal_id"/>
                            <button name="action_create_employer_journal"
                                    string="Create Employer Journal"
                                    type="object"
                                    class="btn-secondary"
                                    invisible="employer_journal_id != False"/>
                        </group>
                    </group>

                    <!-- Financial Summary -->
                    <group string="Financial Summary" invisible="state == 'draft'">
                        <group string="Invoices">
                            <field name="total_invoiced" readonly="1"/>
                            <field name="total_paid_invoices" readonly="1"/>
                            <field name="outstanding_invoices" readonly="1"/>
                        </group>
                        <group string="Expenses">
                            <field name="total_expenses" readonly="1"/>
                        </group>
                    </group>
                    <!-- Account Balances -->
                    <group string="Account Balances" invisible="state == 'draft'">
                        <group string="Payroll Card">
                            <field name="total_card_deposits" readonly="1"/>
                            <field name="total_paid_from_card" readonly="1"/>
                            <field name="payroll_card_balance" readonly="1"
                                   class="fw-bold"/>
                        </group>
                        <group string="Employer">
                            <field name="total_paid_by_employer" readonly="1"/>
                        </group>
                    </group>

                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Project description, scope, or notes..."/>
                    </group>
                </sheet>
                 <chatter/>
            </form>
        </field>
    </record>

    <!-- ===================================================================
         Project: Search View
    =================================================================== -->
    <record id="view_construction_project_search" model="ir.ui.view">
        <field name="name">construction.project.search</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <search string="Search Projects">
                <field name="name" string="Project"/>
                <field name="code"/>
                <field name="employer_id"/>
                <field name="manager_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Closed" name="closed" domain="[('state','=','closed')]"/>
                <separator/>
                <filter string="My Projects" name="my_projects"
                        domain="[('manager_id','=',uid)]"/>
                <group>
                    <filter string="Employer" name="group_employer"
                            context="{'group_by': 'employer_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Manager" name="group_manager"
                            context="{'group_by': 'manager_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_construction_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">construction.project</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_construction_project_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first construction project
            </p>
            <p>
                Manage contractor projects with payroll cards, expenses, and invoices.
            </p>
        </field>
    </record>
</odoo>
