<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Contractor Fee Payment: List View
    =================================================================== -->
    <record id="view_contractor_fee_payment_list" model="ir.ui.view">
        <field name="name">construction.contractor.fee.payment.list</field>
        <field name="model">construction.contractor.fee.payment</field>
        <field name="arch" type="xml">
            <list string="Contractor Fee Payments"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date" widget="jalali_date"/>
                <field name="description"/>
                <field name="journal_id"/>
                <field name="receipt_ref"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ===================================================================
         Contractor Fee Payment: Form View
    =================================================================== -->
    <record id="view_contractor_fee_payment_form" model="ir.ui.view">
        <field name="name">construction.contractor.fee.payment.form</field>
        <field name="model">construction.contractor.fee.payment</field>
        <field name="arch" type="xml">
            <form string="Contractor Fee Payment">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('confirmed', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Payment Details">
                            <field name="project_id"/>
                            <field name="date" widget="jalali_date"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="journal_id"/>
                            <field name="description" placeholder="Description of this fee payment..."/>
                        </group>
                        <group string="Receipt">
                            <field name="receipt_ref" placeholder="Receipt or voucher number"/>
                            <field name="receipt_file" widget="binary" filename="receipt_filename"/>
                            <field name="receipt_filename" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ===================================================================
         Contractor Fee Payment: Search View
    =================================================================== -->
    <record id="view_contractor_fee_payment_search" model="ir.ui.view">
        <field name="name">construction.contractor.fee.payment.search</field>
        <field name="model">construction.contractor.fee.payment</field>
        <field name="arch" type="xml">
            <search string="Search Fee Payments">
                <field name="name" string="Reference"/>
                <field name="project_id"/>
                <field name="journal_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
                <group>
                    <filter string="Project" name="group_project"
                            context="{'group_by': 'project_id'}"/>
                    <filter string="Journal" name="group_journal"
                            context="{'group_by': 'journal_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: from smart button (project-scoped) -->
    <record id="action_contractor_fee_payment" model="ir.actions.act_window">
        <field name="name">Contractor Fee Payments</field>
        <field name="res_model">construction.contractor.fee.payment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_contractor_fee_payment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No contractor fee payments yet</p>
            <p>Record payments made to the contractor for their percentage of the project.</p>
        </field>
    </record>

    <!-- Action: top-level menu (all projects) -->
    <record id="action_contractor_fee_payment_all" model="ir.actions.act_window">
        <field name="name">Contractor Fee Payments</field>
        <field name="res_model">construction.contractor.fee.payment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_contractor_fee_payment_search"/>
        <field name="context">{'search_default_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No contractor fee payments yet</p>
            <p>Record and track all contractor fee payments across projects.</p>
        </field>
    </record>
</odoo>
