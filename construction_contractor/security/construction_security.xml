<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Project Manager group -->
        <record id="group_construction_manager" model="res.groups">
            <field name="name">Project Manager</field>
            <field name="comment">Can create and manage projects, record expenses, and view reports.</field>
        </record>

        <!-- Accountant group -->
        <record id="group_construction_accountant" model="res.groups">
            <field name="name">Accountant</field>
            <field name="implied_ids" eval="[(4, ref('group_construction_manager'))]"/>
            <field name="comment">Full access: deposits, invoices, payments, reports, and financial data.</field>
        </record>

        <!-- Grant Administrator full access to the Construction module -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_construction_accountant'))]"/>
        </record>
    </data>
</odoo>
