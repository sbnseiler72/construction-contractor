<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Project Financial Summary Report
    =================================================================== -->
    <template id="report_construction_project_summary_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="project">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h2>Project Financial Summary</h2>
                                <h3 t-esc="project.name"/>
                                <p>Code: <span t-esc="project.code"/></p>
                            </div>
                        </div>

                        <!-- Project Info -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Employer</strong></td>
                                        <td t-esc="project.employer_id.name"/>
                                    </tr>
                                    <tr>
                                        <td><strong>Manager</strong></td>
                                        <td t-esc="project.manager_id.name"/>
                                    </tr>
                                    <tr>
                                        <td><strong>Start Date</strong></td>
                                        <td t-esc="project.date_start"/>
                                    </tr>
                                    <tr>
                                        <td><strong>End Date</strong></td>
                                        <td t-esc="project.date_end"/>
                                    </tr>
                                    <tr>
                                        <td><strong>Status</strong></td>
                                        <td t-esc="dict(project._fields['state'].selection).get(project.state)"/>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Contracted Amount</strong></td>
                                        <td class="text-end">
                                            <t t-esc="project.contracted_amount"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Total Card Deposits</strong></td>
                                        <td class="text-end">
                                            <t t-esc="project.total_card_deposits"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Total Expenses</strong></td>
                                        <td class="text-end">
                                            <t t-esc="project.total_expenses"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Total Invoiced</strong></td>
                                        <td class="text-end">
                                            <t t-esc="project.total_invoiced"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Total Paid on Invoices</strong></td>
                                        <td class="text-end">
                                            <t t-esc="project.total_paid_invoices"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr class="table-warning">
                                        <td><strong>Outstanding Balance</strong></td>
                                        <td class="text-end">
                                            <strong>
                                                <t t-esc="project.outstanding_invoices"
                                                   t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Expenses by Phase -->
                        <h4 class="mt-4">Expenses by Project Phase</h4>
                        <t t-set="phase_expenses" t-value="project.env['construction.expense'].search([
                            ('project_id','=',project.id),
                            ('state','=','confirmed'),
                            ('project_phase_id','!=',False),
                        ])"/>
                        <t t-if="phase_expenses">
                            <t t-set="phases_used" t-value="phase_expenses.mapped('project_phase_id')"/>
                            <table class="table table-bordered table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Project Phase</th>
                                        <th class="text-end">Total Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="phases_used" t-as="phase">
                                        <tr>
                                            <td t-esc="phase.label"/>
                                            <td class="text-end">
                                                <t t-esc="sum(phase_expenses.filtered(lambda e: e.project_phase_id.id == phase.id).mapped('amount'))"
                                                   t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Expenses by Type -->
                        <h4 class="mt-4">Expenses by Type</h4>
                        <t t-set="expense_types" t-value="project.env['construction.expense.type'].search([('active','=',True)], order='sequence, id')"/>
                        <table class="table table-bordered table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Expense Type</th>
                                    <th class="text-end">Total Amount</th>
                                    <th>In Contractor Fee</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="expense_types" t-as="etype">
                                    <t t-set="etype_expenses" t-value="project.env['construction.expense'].search([
                                        ('project_id','=',project.id),
                                        ('state','=','confirmed'),
                                        ('expense_type_id','=',etype.id),
                                    ])"/>
                                    <t t-if="etype_expenses">
                                        <tr t-att-class="'' if etype.include_in_contractor_fee else 'table-light text-muted'">
                                            <td>
                                                <t t-esc="etype.label"/>
                                                <t t-if="not etype.include_in_contractor_fee">
                                                    <small class="ms-1 text-muted">(excl.)</small>
                                                </t>
                                            </td>
                                            <td class="text-end">
                                                <t t-esc="sum(etype_expenses.mapped('amount'))"
                                                   t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="etype.include_in_contractor_fee">✓</t>
                                                <t t-else="">—</t>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>

                        <!-- Payroll Card Ledger -->
                        <h4 class="mt-4">Payroll Card Ledger</h4>
                        <t t-set="card_txns" t-value="project.env['construction.card.transaction'].search([
                            ('project_id','=',project.id),
                            ('state','=','confirmed'),
                        ], order='date asc')"/>
                        <table class="table table-bordered table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Reference</th>
                                    <th>Description</th>
                                    <th>Type</th>
                                    <th class="text-end">Deposit</th>
                                    <th class="text-end">Withdrawal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="card_txns" t-as="txn">
                                    <tr>
                                        <td t-esc="txn.date"/>
                                        <td t-esc="txn.receipt_ref or txn.name"/>
                                        <td t-esc="txn.description"/>
                                        <td t-esc="dict(txn._fields['transaction_type'].selection).get(txn.transaction_type)"/>
                                        <td class="text-end">
                                            <t t-if="txn.transaction_type == 'deposit'">
                                                <t t-esc="txn.amount"
                                                   t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                            </t>
                                        </td>
                                        <td class="text-end">
                                            <t t-if="txn.transaction_type == 'withdrawal'">
                                                <t t-esc="txn.amount"
                                                   t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Invoice Status -->
                        <h4 class="mt-4">Invoice Status</h4>
                        <t t-set="invoices" t-value="project.env['construction.invoice'].search([
                            ('project_id','=',project.id),
                        ], order='invoice_date asc')"/>
                        <table class="table table-bordered table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Invoice No.</th>
                                    <th>Vendor</th>
                                    <th>Project Phase</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-end">Paid</th>
                                    <th class="text-end">Outstanding</th>
                                    <th>Status</th>
                                    <th>In Contractor Fee</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="invoices" t-as="inv">
                                    <tr t-att-class="'' if inv.include_in_contractor_fee else 'table-light text-muted'">
                                        <td t-esc="inv.invoice_date"/>
                                        <td>
                                            <t t-esc="inv.invoice_number or inv.name"/>
                                            <t t-if="not inv.include_in_contractor_fee">
                                                <small class="ms-1 text-muted">(excl.)</small>
                                            </t>
                                        </td>
                                        <td t-esc="inv.partner_id.name"/>
                                        <td t-esc="inv.project_phase_id.label or ''"/>
                                        <td class="text-end">
                                            <t t-esc="inv.amount_total"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="inv.amount_paid"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="inv.amount_residual"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                        <td t-esc="inv.payment_state"/>
                                        <td class="text-center">
                                            <t t-if="inv.include_in_contractor_fee">✓</t>
                                            <t t-else="">—</t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Payment Source Breakdown (Expenses + Invoice Payments) -->
                        <h4 class="mt-4">Payment Source Breakdown</h4>
                        <t t-set="confirmed_expenses" t-value="project.env['construction.expense'].search([
                            ('project_id','=',project.id),
                            ('state','=','confirmed'),
                        ])"/>
                        <t t-set="all_invoices" t-value="project.env['construction.invoice'].search([
                            ('project_id','=',project.id),
                        ])"/>
                        <table class="table table-bordered table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Payment Source</th>
                                    <th class="text-end">Expenses</th>
                                    <th class="text-end">Invoice Payments</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="exp_card" t-value="sum(confirmed_expenses.filtered(lambda e: e.payment_source == 'payroll_card').mapped('amount'))"/>
                                <t t-set="exp_cash" t-value="sum(confirmed_expenses.filtered(lambda e: e.payment_source == 'employer_cash').mapped('amount'))"/>
                                <t t-set="exp_check" t-value="sum(confirmed_expenses.filtered(lambda e: e.payment_source == 'employer_check').mapped('amount'))"/>
                                <t t-set="inv_card" t-value="sum(all_invoices.filtered(lambda i: i.payment_source == 'payroll_card').mapped('amount_paid'))"/>
                                <t t-set="inv_cash" t-value="sum(all_invoices.filtered(lambda i: i.payment_source == 'employer_cash').mapped('amount_paid'))"/>
                                <t t-set="inv_check" t-value="sum(all_invoices.filtered(lambda i: i.payment_source == 'employer_check').mapped('amount_paid'))"/>
                                <tr>
                                    <td>Payroll Card</td>
                                    <td class="text-end">
                                        <t t-esc="exp_card"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="inv_card"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                    <td class="text-end fw-bold">
                                        <t t-esc="exp_card + inv_card"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Employer Cash</td>
                                    <td class="text-end">
                                        <t t-esc="exp_cash"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="inv_cash"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                    <td class="text-end fw-bold">
                                        <t t-esc="exp_cash + inv_cash"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Employer Check</td>
                                    <td class="text-end">
                                        <t t-esc="exp_check"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="inv_check"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                    <td class="text-end fw-bold">
                                        <t t-esc="exp_check + inv_check"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                </tr>
                                <!-- Payroll Card Balance row -->
                                <tr class="table-info">
                                    <td colspan="3"><strong>Payroll Card Balance (Deposits − Card Payments)</strong></td>
                                    <td class="text-end fw-bold">
                                        <t t-esc="project.payroll_card_balance"
                                           t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Contractor Fee Summary -->
                        <t t-if="project.contractor_percentage">
                            <h4 class="mt-4">Contractor Fee Summary</h4>
                            <table class="table table-bordered table-sm">
                                <tbody>
                                    <tr>
                                        <td><strong>Contractor Percentage</strong></td>
                                        <td class="text-end">
                                            <t t-esc="'%.2f%%' % project.contractor_percentage"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Eligible Cost Base
                                            <small class="text-muted ms-1">(confirmed expenses + paid invoices marked for inclusion)</small>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="project.contractor_fee_base"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr class="table-warning">
                                        <td><strong>Total Contractor Fee</strong>
                                            <small class="text-muted ms-1">(<t t-esc="'%.2f%%' % project.contractor_percentage"/> of base)</small>
                                        </td>
                                        <td class="text-end fw-bold">
                                            <t t-esc="project.total_contractor_fee"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Fee Payments Made to Contractor</td>
                                        <td class="text-end">
                                            <t t-esc="project.contractor_fee_paid"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr t-att-class="'table-danger' if project.contractor_fee_balance > 0 else 'table-success'">
                                        <td><strong>Fee Balance Owed to Contractor</strong></td>
                                        <td class="text-end fw-bold">
                                            <t t-esc="project.contractor_fee_balance"
                                               t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- Contractor Fee Payment Detail -->
                            <t t-set="fee_payments" t-value="project.env['construction.contractor.fee.payment'].search([
                                ('project_id','=',project.id),
                                ('state','=','confirmed'),
                            ], order='date asc')"/>
                            <t t-if="fee_payments">
                                <h5 class="mt-3">Contractor Fee Payments Detail</h5>
                                <table class="table table-bordered table-sm">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Reference</th>
                                            <th>Date</th>
                                            <th>Description</th>
                                            <th class="text-end">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="fee_payments" t-as="fp">
                                            <tr>
                                                <td t-esc="fp.name"/>
                                                <td t-esc="fp.date"/>
                                                <td t-esc="fp.description or ''"/>
                                                <td class="text-end">
                                                    <t t-esc="fp.amount"
                                                       t-options="{'widget': 'monetary', 'display_currency': project.currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                        </t>

                        <div class="text-muted mt-4">
                            <small>Report generated on
                                <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                            </small>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
